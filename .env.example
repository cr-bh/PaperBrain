# =============================================================
# PaperBrain 环境配置
# 复制本文件为 .env 并填入你的配置
# 或者直接在应用内「⚙️ 设置」页面配置（推荐）
# =============================================================

# ----- LLM API 配置 -----
# 推荐通过设置页面配置，以下为手动配置方式
#
# 支持的提供商（OpenAI 兼容格式）:
#   DeepSeek:     https://api.deepseek.com/v1
#   通义千问:     https://dashscope.aliyuncs.com/compatible-mode/v1
#   OpenAI:       https://api.openai.com/v1
#   Moonshot:     https://api.moonshot.cn/v1
#   智谱 GLM:     https://open.bigmodel.cn/api/paas/v4
#   SiliconFlow:  https://api.siliconflow.cn/v1
#
# 示例（以 DeepSeek 为例）:
LLM_API_URL=https://api.deepseek.com/v1/chat/completions
LLM_BEARER_TOKEN=your_api_key_here

# ----- 评分 LLM 配置（可选）-----
# 用于 Auto-Scholar 论文评分，不配置则复用主 LLM
# DOUBAO_API_KEY=your_api_key_here
# DOUBAO_BASE_URL=https://api.deepseek.com/v1
# DOUBAO_MODEL=deepseek-chat

# ----- 数据库配置 -----
DATABASE_PATH=data/paperbrain.db
CHROMA_DB_PATH=data/chroma_db

# ----- 文件存储 -----
PAPERS_DIR=data/papers
IMAGES_DIR=data/images

# ----- 模型配置 -----
MODEL_NAME=deepseek-chat
TEMPERATURE=0.7
MAX_TOKENS=8192

# ----- RAG 配置 -----
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5

# ----- Auto-Scholar 配置 -----
ARXIV_CATEGORIES=cs.AI,cs.LG,cs.CL,math.OC
ARXIV_MAX_RESULTS=200
SCORE_THRESHOLD=5.0

# ----- 筛选配置 -----
KEYWORD_MIN_MATCHES=2
S2_MIN_CITATIONS=3
S2_MIN_INFLUENTIAL=1
S2_API_KEY=

# ----- S2 API 重试配置 -----
S2_MAX_RETRIES=3
S2_RETRY_DELAY=1.0
S2_REQUEST_INTERVAL=0.3
S2_CACHE_PATH=data/s2_cache.json

# ----- 降级规则关键词（逗号分隔）-----
S2_FALLBACK_KEYWORDS=large language model,llm,transformer,bert,gpt,attention mechanism,neural network,deep learning,machine learning,reinforcement learning,computer vision,natural language processing,nlp
